# Copy this file to .env and fill in your values.

# Base URL of your deployed Next.js web app (no trailing slash).
# In development this can be your local IP (e.g. http://192.168.1.5:3000).
EXPO_PUBLIC_API_URL=https://your-app.vercel.app

# Clerk publishable key (same Clerk project as the web app).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Supabase credentials (anon key — never the service role key).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
